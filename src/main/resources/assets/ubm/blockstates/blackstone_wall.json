{
  "multipart": [
    {
      "apply": { "model": "ubm:blackstone_post" }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "ubm:blackstone_side" }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "ubm:blackstone_side", "y": 90 }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "ubm:blackstone_side", "y": 180 }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "ubm:blackstone_side", "y": 270 }
    }
  ]
}
